# Copy to apps/api/.env and fill in. Keys marked REQUIRED are needed even
# in dev; optional ones gracefully degrade (see comments).

# ── core ─────────────────────────────────────────────────────────────────
APP_ENV=development
# REQUIRED — must be ≥32 chars in prod. Generate with `openssl rand -base64 36`
SECRET_KEY=dev-secret-change-me-in-prod-min-32-chars
ALLOWED_ORIGINS=http://localhost:3000

# ── allowlist (REQUIRED) ─────────────────────────────────────────────────
# Only these two emails can request a magic-link.
ESUI_EMAIL=
BADRUSHK_EMAIL=ulziibadrakhtseren@gmail.com

# ── postgres ─────────────────────────────────────────────────────────────
# Native install: run `infra/local/setup-postgres.ps1` first to create the
# `esui` database and role, then either keep the default 5432 below or
# change it to 5433 if a prior install grabbed your default port.
# Docker (optional): `pnpm db:up` brings up postgres on 5432 ready to go.
DATABASE_URL=postgresql+asyncpg://esui:esui@localhost:5432/esui

# ── redis ────────────────────────────────────────────────────────────────
# Memurai (Windows): `winget install Memurai.MemuraiDeveloper` — exposes 6379.
# Upstash (cloud): paste the rediss:// URL from the Upstash dashboard.
# Docker (optional): comes from `pnpm db:up`.
REDIS_URL=redis://localhost:6379/0

# ── R2 (optional in dev — file uploads disabled until set) ───────────────
R2_ENDPOINT_URL=
R2_BUCKET=esui-files
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ── anthropic (REQUIRED for chat / planner / exam generation) ────────────
ANTHROPIC_API_KEY=
OPUS_MODEL_ID=claude-opus-4-7
SONNET_MODEL_ID=claude-sonnet-4-6
HAIKU_MODEL_ID=claude-haiku-4-5

# ── google gemini (required for market_research routes) ──────────────────
GOOGLE_API_KEY=
GEMINI_MODEL_ID=gemini-3.1-pro

# ── perplexity sonar (required for deep_research routes) ─────────────────
PERPLEXITY_API_KEY=
PERPLEXITY_RESEARCH_MODEL_ID=sonar-deep-research
PERPLEXITY_REASONING_MODEL_ID=sonar-reasoning-pro

# ── voyage embeddings (required for vault search) ────────────────────────
VOYAGE_API_KEY=

# ── unstructured (optional file parsing) ─────────────────────────────────
UNSTRUCTURED_API_KEY=
UNSTRUCTURED_API_URL=https://api.unstructured.io

# ── email — magic links ──────────────────────────────────────────────────
# Empty in dev → the magic-link URL prints to the API log instead of being
# emailed. Copy it from the terminal into the browser.
RESEND_API_KEY=
RESEND_FROM=auth@esui.app

# ── cost guard ───────────────────────────────────────────────────────────
DAILY_COST_CAP_USD=20

# ── frontend (apps/web/.env.local) ───────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_WS_URL=ws://localhost:8000
